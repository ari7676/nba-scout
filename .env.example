# Copiá este archivo como .env y completá los valores

# Base de datos PostgreSQL (Railway lo genera automáticamente)
DATABASE_URL=postgresql://user:password@localhost/nba_scout

# Clave secreta para JWT — generá una con: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET

# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# The Odds API (opcional) — https://the-odds-api.com — free tier: 500 req/mes
ODDS_API_KEY=

# CORS — URLs del frontend separadas por coma
# En desarrollo: http://localhost:5173
# En producción: https://tu-app.up.railway.app
ALLOWED_ORIGINS=http://localhost:5173
